# ============================================================
# Variáveis de ambiente — copie para .env e preencha.
# O .env NÃO vai para o git (está no .gitignore).
# ============================================================

# Porta do painel (opcional, padrão 3000)
# PORT=3000

# ---- Supabase (OBRIGATÓRIO) — Postgres + Auth ----
# Sem estas variáveis o app não sobe. Pegue no painel do Supabase:
#   DATABASE_URL: Settings → Database → Connection string → URI
#                 (prefira o Session pooler, porta 5432). Se a senha tiver
#                 caracteres especiais como #, troque a senha por uma só com
#                 letras e números, ou use aspas + percent-encoding.
#   SUPABASE_*:   Settings → API
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
# service_role é admin TOTAL do banco — só backend, nunca no front/git.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Conta master do SUPER-ADMIN ----
# Conta fixa, separada dos restaurantes, que gerencia todos os tenants.
# Sem essas duas variáveis, as rotas /api/admin/* ficam desativadas (login responde 503).
# BOOTSTRAP: depois do 1º acesso, dá pra trocar e-mail/senha do master pela aba
# "Configurações Master" (passam a viver no banco, em plataforma_config); estas envs
# continuam valendo como fallback e como gate que habilita o /api/admin/*.

# E-mail de acesso do super-admin
SUPERADMIN_EMAIL=

# Hash SHA-256 da senha master. NUNCA coloque a senha em texto puro aqui.
# Gere o hash com (usa o mesmo salt do projeto):
#   npm run gerar-hash-admin -- "suaSenhaForte"
# e cole o valor retornado abaixo.
SUPERADMIN_SENHA_HASH=

# ---- Stripe (assinatura paga) ----
# Painel do Stripe (modo Teste): Desenvolvedores → Chaves de API.
# Em produção use chaves sk_live_/pk_live_ (via secrets do host, nunca no git).
#   STRIPE_PRICE_ID:       Catálogo de produtos → o preço recorrente (price_...)
#   STRIPE_WEBHOOK_SECRET: gerado por `stripe listen` (dev) ou no endpoint do
#                          webhook em Desenvolvedores → Webhooks (produção).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# ---- Plataforma (Nymbus) ----
# WhatsApp de suporte exibido ao cliente (botão "Falar com Suporte" na aba
# Assinatura). Só dígitos, formato internacional p/ wa.me (ex.: 5511999999999).
# Vazio = o card "Precisa de ajuda?" fica oculto. No futuro, a aba "Nymbus" do
# painel master passa a gerenciar este e outros dados da plataforma.
SUPORTE_WHATSAPP=
